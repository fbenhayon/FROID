# ============================================================
# FROID v3.0 - Variaveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# Identity Database (PostgreSQL separado para PII)
ID_DB_PASSWORD=changeme_identity

# Clinical Database
CLINICAL_DB_PASSWORD=changeme_clinical

# Identity Vault Service
DATABASE_URL=postgresql://froid_id:changeme_identity@localhost:5432/froid_identity

# Redis
REDIS_URL=redis://localhost:6379

# API
PORT=3001
NODE_ENV=development