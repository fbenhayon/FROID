services:
  postgres:
    image: postgres:15-alpine
    container_name: froid-postgres-1
    environment:
      POSTGRES_USER: froid
      POSTGRES_PASSWORD: froid_password
      POSTGRES_DB: froid_db
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U froid"]
      interval: 5s
      timeout: 5s
      retries: 5
    networks:
      - froid-network
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: froid-redis-1
    ports:
      - "6379:6379"
    networks:
      - froid-network
    restart: unless-stopped

  identity-vault:
    build:
      context: .
      dockerfile: packages/identity-vault/Dockerfile
    container_name: froid-identity-vault-1
    ports:
      - "8001:3001"
    environment:
      - DATABASE_URL=postgresql://froid:froid_password@postgres:5432/froid_db
      - REDIS_URL=redis://redis:6379
      - JWT_SECRET=froid_jwt_secret_2024
      - PORT=3001
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
    networks:
      - froid-network
    restart: unless-stopped

  froid-voice:
    build:
      context: .
      dockerfile: packages/froid-voice/Dockerfile
    container_name: froid-voice-1
    ports:
      - "3002:3002"
    environment:
      - PORT=3002
    networks:
      - froid-network
    restart: unless-stopped

  froid-face:
    build:
      context: .
      dockerfile: packages/froid-face/Dockerfile
    container_name: froid-face-1
    ports:
      - "3003:3003"
    environment:
      - PORT=3003
    networks:
      - froid-network
    restart: unless-stopped

  froid-dashboard:
    build:
      context: .
      dockerfile: packages/froid-dashboard/Dockerfile
      args:
        - VITE_API_URL=http://204.168.229.32:8001
    container_name: froid-dashboard-1
    ports:
      - "80:80"
    depends_on:
      - identity-vault
    networks:
      - froid-network
    restart: unless-stopped

  froid-payment:
    build:
context: ./packages/froid-payment
      dockerfile: Dockerfile      

    container_name: froid-payment-1
    ports:
      - "3004:3004"
    environment:
      - PORT=3004
      - DATABASE_URL=postgresql://froid:froid_password@postgres:5432/froid_db
    depends_on:
      - postgres
    networks:
      - froid-network
    restart: unless-stopped

networks:
  froid-network:
    driver: bridge

volumes:
  pgdata:
