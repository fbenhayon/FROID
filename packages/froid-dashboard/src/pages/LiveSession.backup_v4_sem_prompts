import { useState, useEffect, useRef } from 'react';
import { useParams, useNavigate } from 'react-router-dom';
import {
  Chart as ChartJS,
  CategoryScale,
  LinearScale,
  BarElement,
  LineElement,
  PointElement,
  Title,
  Tooltip,
  Legend,
} from 'chart.js';
import { Bar, Line } from 'react-chartjs-2';

ChartJS.register(
  CategoryScale,
  LinearScale,
  BarElement,
  LineElement,
  PointElement,
  Title,
  Tooltip,
  Legend
);

export function LiveSession() {
  const { patientId } = useParams();
  const navigate = useNavigate();
  const [session, setSession] = useState<any>(null);
  const [voiceStatus, setVoiceStatus] = useState('connecting');
  const [faceStatus, setFaceStatus] = useState('connecting');
  const [currentZone, setCurrentZone] = useState<string>('');
  const [currentEmotion, setCurrentEmotion] = useState<string>('');
  const [notes, setNotes] = useState<Array<{text: string, timestamp: string}>>([]);
  const [currentNote, setCurrentNote] = useState<string>('');
  
  // Dados dos gráficos em tempo real
  const [zoneData, setZoneData] = useState<number[]>(new Array(12).fill(0));
  const [bandData, setBandData] = useState<number[]>(new Array(7).fill(0));
  const [emotionHistory, setEmotionHistory] = useState<string[]>([]);
  const [riskScores, setRiskScores] = useState({ depression: 0, mania: 0, stress: 0 });
  const [colorimetryLevel, setColorimetryLevel] = useState(0);
  const [ipmScore, setIpmScore] = useState(0); // IPM - Índice de Congruência Multimodal
  const [ipmHistory, setIpmHistory] = useState<number[]>([]); // Histórico últimos 20
  
  const videoRef = useRef<HTMLVideoElement>(null);
  const voiceWsRef = useRef<WebSocket | null>(null);
  const faceWsRef = useRef<WebSocket | null>(null);

  useEffect(() => {
    initializeSession();
    return () => cleanup();
  }, []);

  const initializeSession = async () => {
    try {
      const user = JSON.parse(localStorage.getItem('user') || '{}');
      const response = await fetch('http://167.71.182.244:3001/sessions', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${localStorage.getItem('token')}`,
        },
        body: JSON.stringify({
          patientId,
          professionalId: user.id,
          scheduledFor: new Date().toISOString(),
        }),
      });

      const sessionData = await response.json();
      setSession(sessionData);

      connectVoiceWebSocket(sessionData.id);
      connectFaceWebSocket(sessionData.id);
      startCamera();
    } catch (error) {
      console.error('Erro ao inicializar sessão:', error);
      alert('Erro ao iniciar sessão');
    }
  };

  const connectVoiceWebSocket = (sessionId: string) => {
    const ws = new WebSocket(`ws://167.71.182.244:3002/ws/voice/${sessionId}`);
    
    ws.onopen = () => {
      console.log('WebSocket Voice conectado');
      setVoiceStatus('connected');
    };
    
    ws.onmessage = (event) => {
      const data = JSON.parse(event.data);
      
      if (data.dominant_zone) {
        setCurrentZone(data.dominant_zone);
      }
      
      if (data.zones) {
        setZoneData(data.zones);
      }
      
      if (data.spectral_bands) {
        setBandData(data.spectral_bands);
      }
      
      if (data.clinical_scores) {
        setRiskScores({
          depression: data.clinical_scores.depression_risk || 0,
          mania: data.clinical_scores.mania_activation || 0,
          stress: data.clinical_scores.stress_cognitive || 0,
        });
      }
      
      if (data.colorimetry_level !== undefined) {
        setColorimetryLevel(data.colorimetry_level);
      }
      
      // IPM - Índice de Congruência (enviado pelo backend)
      if (data.ipm_score !== undefined) {
        setIpmScore(data.ipm_score);
        setIpmHistory(prev => [...prev.slice(-19), data.ipm_score]);
      }
    };
    
    ws.onerror = () => setVoiceStatus('error');
    ws.onclose = () => setVoiceStatus('disconnected');
    
    voiceWsRef.current = ws;
  };

  const connectFaceWebSocket = (sessionId: string) => {
    const ws = new WebSocket(`ws://167.71.182.244:3003/ws/face/${sessionId}`);
    
    ws.onopen = () => {
      console.log('WebSocket Face conectado');
      setFaceStatus('connected');
    };
    
    ws.onmessage = (event) => {
      const data = JSON.parse(event.data);
      
      if (data.dominant_emotion) {
        setCurrentEmotion(data.dominant_emotion);
        setEmotionHistory(prev => [...prev.slice(-19), data.dominant_emotion]);
      }
    };
    
    ws.onerror = () => setFaceStatus('error');
    ws.onclose = () => setFaceStatus('disconnected');
    
    faceWsRef.current = ws;
  };

  const startCamera = async () => {
    try {
      const stream = await navigator.mediaDevices.getUserMedia({
        video: { width: 640, height: 480 },
        audio: true,
      });
      
      if (videoRef.current) {
        videoRef.current.srcObject = stream;
      }
    } catch (error) {
      console.error('Erro ao acessar câmera:', error);
      alert('Erro ao acessar câmera/microfone');
    }
  };

  const addNote = () => {
    if (!currentNote.trim()) return;
    
    const newNote = {
      text: currentNote,
      timestamp: new Date().toLocaleTimeString('pt-BR'),
    };
    
    setNotes([...notes, newNote]);
    setCurrentNote('');
  };

  const endSession = async () => {
    if (!session) return;
    
    try {
      await fetch(`http://167.71.182.244:3001/sessions/${session.id}/end`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'Authorization': `Bearer ${localStorage.getItem('token')}`,
        },
        body: JSON.stringify({
          clinicalNotes: notes.map(n => `[${n.timestamp}] ${n.text}`).join('\n'),
        }),
      });
      
      cleanup();
      navigate('/dashboard');
    } catch (error) {
      console.error('Erro ao finalizar sessão:', error);
    }
  };

  const cleanup = () => {
    if (voiceWsRef.current) voiceWsRef.current.close();
    if (faceWsRef.current) faceWsRef.current.close();
    
    if (videoRef.current?.srcObject) {
      const stream = videoRef.current.srcObject as MediaStream;
      stream.getTracks().forEach(track => track.stop());
    }
  };

  // Configuração do gráfico de 12 Zonas FROID
  const zoneChartData = {
    labels: ['C2', 'C#2', 'C3', 'C#3', 'C4', 'C#4', 'C5', 'C#5', 'C6', 'C#6', 'C7', 'C#7'],
    datasets: [{
      label: 'Intensidade',
      data: zoneData,
      backgroundColor: [
        'rgba(255, 99, 132, 0.8)',
        'rgba(255, 159, 64, 0.8)',
        'rgba(255, 205, 86, 0.8)',
        'rgba(75, 192, 192, 0.8)',
        'rgba(54, 162, 235, 0.8)',
        'rgba(153, 102, 255, 0.8)',
        'rgba(231, 233, 237, 0.8)',
        'rgba(255, 99, 132, 0.6)',
        'rgba(255, 159, 64, 0.6)',
        'rgba(255, 205, 86, 0.6)',
        'rgba(75, 192, 192, 0.6)',
        'rgba(54, 162, 235, 0.6)',
      ],
    }],
  };

  const zoneChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    scales: {
      y: { beginAtZero: true, max: 100 },
    },
    plugins: {
      legend: { display: false },
      title: { display: true, text: '12 Zonas FROID', color: '#fff' },
    },
  };

  // Configuração do gráfico de 7 Bandas Espectrais
  const bandChartData = {
    labels: ['Subharmonics', 'Delta', 'Theta', 'Alpha', 'Beta', 'Gamma', 'High-Gamma'],
    datasets: [{
      label: 'Potência',
      data: bandData,
      borderColor: 'rgb(75, 192, 192)',
      backgroundColor: 'rgba(75, 192, 192, 0.2)',
      tension: 0.4,
    }],
  };

  const bandChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    scales: {
      y: { beginAtZero: true, max: 100 },
    },
    plugins: {
      legend: { display: false },
      title: { display: true, text: '7 Bandas Espectrais', color: '#fff' },
    },
  };

  // Configuração do gráfico IPM Timeline
  const ipmChartData = {
    labels: ipmHistory.map((_, i) => `${i + 1}`),
    datasets: [{
      label: 'IPM',
      data: ipmHistory,
      borderColor: 'rgb(147, 51, 234)',
      backgroundColor: 'rgba(147, 51, 234, 0.1)',
      tension: 0.4,
      fill: true,
    }],
  };

  const ipmChartOptions = {
    responsive: true,
    maintainAspectRatio: false,
    scales: {
      y: { beginAtZero: true, max: 100 },
      x: { display: false },
    },
    plugins: {
      legend: { display: false },
    },
  };

  // Cores da Colorimetria
  const colorimetryColors = [
    '#FF0000', // Vermelho
    '#FF7F00', // Laranja
    '#FFFF00', // Amarelo
    '#00FF00', // Verde
    '#0000FF', // Azul
    '#4B0082', // Índigo
    '#9400D3', // Violeta
  ];

  const getRiskColor = (score: number) => {
    if (score < 30) return 'bg-green-500';
    if (score < 60) return 'bg-yellow-500';
    return 'bg-red-500';
  };

  const getRiskLabel = (score: number) => {
    if (score < 30) return 'Baixo';
    if (score < 60) return 'Moderado';
    return 'Alto';
  };

  const getIPMColor = (score: number) => {
    if (score >= 70) return 'text-green-400';
    if (score >= 40) return 'text-yellow-400';
    return 'text-red-400';
  };

  const getIPMLabel = (score: number) => {
    if (score >= 70) return 'Alta Congruência';
    if (score >= 40) return 'Congruência Moderada';
    return 'Incongruência Detectada';
  };

  const getIPMRingColor = (score: number) => {
    if (score >= 70) return 'ring-green-500';
    if (score >= 40) return 'ring-yellow-500';
    return 'ring-red-500';
  };

  return (
    <div className="min-h-screen bg-gray-900 text-white">
      {/* Header */}
      <div className="bg-gray-800 p-4">
        <div className="max-w-[1920px] mx-auto flex justify-between items-center">
          <h1 className="text-2xl font-bold">🧠 Sessão ao Vivo - Análise Multimodal</h1>
          <button
            onClick={endSession}
            className="px-6 py-2 bg-red-600 hover:bg-red-700 rounded-lg font-semibold"
          >
            Finalizar Sessão
          </button>
        </div>
      </div>

      {/* Main Content - 3 colunas */}
      <div className="max-w-[1920px] mx-auto p-6 grid grid-cols-12 gap-4">
        
        {/* COLUNA 1: Vídeo + Anotações (4 cols) */}
        <div className="col-span-4 space-y-4">
          {/* Video Preview */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h2 className="text-lg font-semibold mb-3">📹 Vídeo</h2>
            <video
              ref={videoRef}
              autoPlay
              playsInline
              muted
              className="w-full rounded-lg bg-black"
            />
          </div>

          {/* Anotações Clínicas */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h2 className="text-lg font-semibold mb-3">📝 Anotações Clínicas</h2>
            
            <div className="mb-3">
              <textarea
                value={currentNote}
                onChange={(e) => setCurrentNote(e.target.value)}
                placeholder="Registre suas observações..."
                className="w-full h-20 px-3 py-2 bg-gray-700 text-white rounded-lg resize-none text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
                onKeyDown={(e) => {
                  if (e.key === 'Enter' && e.ctrlKey) addNote();
                }}
              />
              <div className="flex justify-between items-center mt-2">
                <span className="text-xs text-gray-400">Ctrl+Enter</span>
                <button
                  onClick={addNote}
                  disabled={!currentNote.trim()}
                  className="px-3 py-1 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-600 rounded text-sm"
                >
                  Adicionar
                </button>
              </div>
            </div>

            <div className="space-y-2 max-h-48 overflow-y-auto">
              {notes.length === 0 ? (
                <p className="text-center text-gray-500 py-3 text-sm">Nenhuma anotação ainda</p>
              ) : (
                notes.map((note, i) => (
                  <div key={i} className="bg-gray-700 rounded p-2">
                    <div className="flex justify-between mb-1">
                      <span className="text-xs text-gray-400">{note.timestamp}</span>
                      <span className="text-xs text-gray-400">#{i + 1}</span>
                    </div>
                    <p className="text-xs">{note.text}</p>
                  </div>
                ))
              )}
            </div>
          </div>
        </div>

        {/* COLUNA 2: Gráficos FROID (5 cols) */}
        <div className="col-span-5 space-y-4">
          
          {/* 12 Zonas FROID */}
          <div className="bg-gray-800 rounded-lg p-4">
            <div className="h-64">
              <Bar data={zoneChartData} options={zoneChartOptions} />
            </div>
            <div className="mt-2 text-center">
              <p className="text-sm text-gray-400">Zona Dominante:</p>
              <p className="text-2xl font-bold text-blue-400">{currentZone || 'Aguardando...'}</p>
            </div>
          </div>

          {/* 7 Bandas Espectrais */}
          <div className="bg-gray-800 rounded-lg p-4">
            <div className="h-48">
              <Line data={bandChartData} options={bandChartOptions} />
            </div>
          </div>

          {/* Colorimetria SVG Animado */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h3 className="text-lg font-semibold mb-3">🎨 Colorimetria (7 Níveis)</h3>
            <div className="flex items-center space-x-2">
              {colorimetryColors.map((color, i) => (
                <div
                  key={i}
                  className={`flex-1 h-12 rounded transition-all duration-300 ${
                    i === colorimetryLevel ? 'ring-4 ring-white scale-110' : 'opacity-50'
                  }`}
                  style={{ backgroundColor: color }}
                />
              ))}
            </div>
            <div className="mt-2 text-center">
              <p className="text-sm text-gray-400">Nível Atual:</p>
              <p className="text-xl font-bold">
                {['Vermelho', 'Laranja', 'Amarelo', 'Verde', 'Azul', 'Índigo', 'Violeta'][colorimetryLevel]}
              </p>
            </div>
          </div>
        </div>

        {/* COLUNA 3: IPM + Indicadores + Timeline (3 cols) */}
        <div className="col-span-3 space-y-4">
          
          {/* IPM - Índice de Congruência Multimodal */}
          <div className="bg-gradient-to-br from-purple-900 to-purple-800 rounded-lg p-4 ring-2 ring-purple-500">
            <h3 className="font-semibold mb-3 flex items-center">
              <span className="text-2xl mr-2">🎯</span>
              IPM - Congruência Multimodal
            </h3>
            
            {/* Medidor circular */}
            <div className="flex justify-center mb-4">
              <div className={`relative w-32 h-32 rounded-full ring-8 ${getIPMRingColor(ipmScore)} flex items-center justify-center bg-gray-900`}>
                <div className="text-center">
                  <p className={`text-4xl font-bold ${getIPMColor(ipmScore)}`}>
                    {ipmScore}%
                  </p>
                  <p className="text-xs text-gray-400 mt-1">{getIPMLabel(ipmScore)}</p>
                </div>
              </div>
            </div>

            {/* Gráfico timeline IPM */}
            <div className="h-20 mb-2">
              {ipmHistory.length > 0 && <Line data={ipmChartData} options={ipmChartOptions} />}
            </div>

            {/* Legenda */}
            <div className="text-xs text-gray-300 bg-gray-900 bg-opacity-50 rounded p-2">
              <p className="font-semibold mb-1">Sobre o IPM:</p>
              <p>Mede a congruência entre voz, face e conteúdo verbal. Valores baixos indicam possível incongruência emocional ou dissociação.</p>
            </div>
          </div>

          {/* Status Conexão */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h3 className="font-semibold mb-3">📡 Status</h3>
            <div className="space-y-2 text-sm">
              <div className="flex justify-between">
                <span>Voice:</span>
                <span className={`px-2 py-1 rounded text-xs ${
                  voiceStatus === 'connected' ? 'bg-green-600' : 'bg-red-600'
                }`}>{voiceStatus}</span>
              </div>
              <div className="flex justify-between">
                <span>Face:</span>
                <span className={`px-2 py-1 rounded text-xs ${
                  faceStatus === 'connected' ? 'bg-green-600' : 'bg-red-600'
                }`}>{faceStatus}</span>
              </div>
              <div className="flex justify-between">
                <span>ID:</span>
                <span className="font-mono text-xs">{session?.id?.substring(0, 8)}</span>
              </div>
            </div>
          </div>

          {/* Riscos Clínicos */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h3 className="font-semibold mb-3">⚠️ Riscos Clínicos</h3>
            <div className="space-y-3">
              {/* Depressão */}
              <div>
                <div className="flex justify-between text-sm mb-1">
                  <span>Depressão</span>
                  <span className="font-semibold">{riskScores.depression}%</span>
                </div>
                <div className="w-full bg-gray-700 rounded-full h-2">
                  <div
                    className={`h-2 rounded-full ${getRiskColor(riskScores.depression)} transition-all duration-500`}
                    style={{ width: `${riskScores.depression}%` }}
                  />
                </div>
                <p className="text-xs text-gray-400 mt-1">{getRiskLabel(riskScores.depression)}</p>
              </div>

              {/* Mania */}
              <div>
                <div className="flex justify-between text-sm mb-1">
                  <span>Mania</span>
                  <span className="font-semibold">{riskScores.mania}%</span>
                </div>
                <div className="w-full bg-gray-700 rounded-full h-2">
                  <div
                    className={`h-2 rounded-full ${getRiskColor(riskScores.mania)} transition-all duration-500`}
                    style={{ width: `${riskScores.mania}%` }}
                  />
                </div>
                <p className="text-xs text-gray-400 mt-1">{getRiskLabel(riskScores.mania)}</p>
              </div>

              {/* Estresse */}
              <div>
                <div className="flex justify-between text-sm mb-1">
                  <span>Estresse Cognitivo</span>
                  <span className="font-semibold">{riskScores.stress}%</span>
                </div>
                <div className="w-full bg-gray-700 rounded-full h-2">
                  <div
                    className={`h-2 rounded-full ${getRiskColor(riskScores.stress)} transition-all duration-500`}
                    style={{ width: `${riskScores.stress}%` }}
                  />
                </div>
                <p className="text-xs text-gray-400 mt-1">{getRiskLabel(riskScores.stress)}</p>
              </div>
            </div>
          </div>

          {/* Timeline de Emoções FACS */}
          <div className="bg-gray-800 rounded-lg p-4">
            <h3 className="font-semibold mb-3">😊 Timeline Emoções (FACS)</h3>
            <div className="space-y-2">
              <div className="text-center mb-3">
                <p className="text-sm text-gray-400">Emoção Atual:</p>
                <p className="text-xl font-bold text-green-400">{currentEmotion || 'Aguardando...'}</p>
              </div>
              <div className="space-y-1 max-h-32 overflow-y-auto text-xs">
                {emotionHistory.slice(-10).reverse().map((emotion, i) => (
                  <div key={i} className="flex justify-between bg-gray-700 rounded px-2 py-1">
                    <span className="text-gray-400">#{emotionHistory.length - i}</span>
                    <span>{emotion}</span>
                  </div>
                ))}
                {emotionHistory.length === 0 && (
                  <p className="text-center text-gray-500 py-2">Sem histórico ainda</p>
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}

