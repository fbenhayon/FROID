{
  "name": "@froid/identity-vault",
  "version": "1.0.0",
  "description": "FROID Identity Vault - Servico de identidade e textos juridicos",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prisma:generate": "prisma generate --schema=src/prisma/schema.prisma",
    "prisma:migrate:dev": "prisma migrate dev --schema=src/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate deploy --schema=src/prisma/schema.prisma",
    "prisma:seed": "ts-node -r tsconfig-paths/register src/seed/legal-texts.ts",
    "prisma:studio": "prisma studio --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "@froid/shared": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^5.11.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.1",
    "@types/node": "^20.11.0",
    "prisma": "^5.11.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma",
    "seed": "ts-node -r tsconfig-paths/register src/seed/legal-texts.ts"
  }
}