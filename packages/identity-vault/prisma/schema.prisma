// FROID v3.2.0 - Schema HÍBRIDO (mantém estrutura atual + adiciona financeiro)
// Data: 2026-05-06

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== MANTÉM ESTRUTURA ATUAL ====================

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  
  // NOVO: OAuth Google
  googleId String? @unique
  picture  String?
  name     String  @default("")
  
  role     String  @default("professional")
  
  professional    Professional?
  patients        Patient[]
  sessions        Session[]
  consents        Consent[]
  
  // NOVO: Financeiro
  subscriptions   Subscription[]
  transactions    Transaction[]
  clinicsOwned    Clinic[]       @relation("ClinicAdmin")
  clinicMemberships ClinicMember[] @relation("ClinicMembership")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("users")
  aiPrompts         AIComparativePrompt[]
}

model Professional {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name      String
  crp       String  @unique
  specialty String?
  bio       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("professionals")
}

model Patient {
  id             String    @id @default(uuid())
  professionalId String
  professional   User      @relation(fields: [professionalId], references: [id])
  
  name           String
  cpf            String    @unique
  birthDate      DateTime
  phone          String?
  email          String?
  
  visibleToProfessionals Boolean @default(true)
  
  // NOVO: Compartilhamento em clínicas
  clinicId       String?
  clinic         Clinic?   @relation(fields: [clinicId], references: [id])
  sharedWith     String[]  @default([])
  
  sessions       Session[]
  consents       Consent[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("patients")
}

model Session {
  id             String    @id @default(uuid())
  patientId      String
  patient        Patient   @relation(fields: [patientId], references: [id])
  professionalId String
  professional   User      @relation(fields: [professionalId], references: [id])
  
  status         String    @default("active")
  scheduledFor   DateTime
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  
  clinicalNotes  String?
  
  // NOVO: Controle financeiro
  clinicId       String?
  clinic         Clinic?   @relation(fields: [clinicId], references: [id])
  creditCharged  Boolean   @default(false)
  
  voiceAnalyses  VoiceAnalysis[]
  facialAnalyses FacialAnalysis[]
  fusionAnalyses FusionAnalysis[]
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  
  @@map("sessions")
}

model VoiceAnalysis {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  data      Json
  
  createdAt DateTime @default(now())
  
  @@map("voice_analyses")
}

model FacialAnalysis {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  data      Json
  
  createdAt DateTime @default(now())
  
  @@map("facial_analyses")
}

model FusionAnalysis {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  
  ipmScore  Float
  data      Json
  
  createdAt DateTime @default(now())
  
  @@map("fusion_analyses")
}

// ==================== MANTÉM LEGAL/LGPD ATUAL ====================

model LegalText {
  id                     String    @id @default(uuid())
  type                   String
  title                  String
  content                String
  version                String
  active                 Boolean   @default(true)
  
  // MANTÉM campos existentes
  shortText              String?
  legalBasis             String?
  audience               String?
  context                String?
  requiresSignature      Boolean   @default(false)
  requiresAction         Boolean   @default(false)
  isBlocking             Boolean   @default(false)
  showCitationInline     Boolean   @default(false)
  visibleToProfessionals Boolean   @default(true)
  effectiveFrom          DateTime  @default(now())
  
  consents Consent[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  
  @@map("legal_texts")
}

model Consent {
  id           String    @id @default(uuid())
  patientId    String
  patient      Patient   @relation(fields: [patientId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  legalTextId  String
  legalText    LegalText @relation(fields: [legalTextId], references: [id])
  
  accepted     Boolean   @default(false)
  ipAddress    String?
  userAgent    String?
  
  createdAt    DateTime  @default(now())
  
  @@unique([patientId, legalTextId])
  @@map("consents")
}

// ==================== NOVO: MÓDULO FINANCEIRO ====================

model Subscription {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  planType         String
  status           String    @default("active")
  
  creditsTotal     Int
  creditsUsed      Int       @default(0)
  creditsRemaining Int
  
  startDate        DateTime  @default(now())
  expiryDate       DateTime?
  
  amount           Decimal   @db.Decimal(10, 2)
  paymentMethod    String
  
  transactionId    String?   @unique
  transaction      Transaction? @relation(fields: [transactionId], references: [id])
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  
  @@index([userId, status])
  @@map("subscriptions")
}

model Transaction {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            String
  status          String    @default("pending")
  
  amount          Decimal   @db.Decimal(10, 2)
  paymentMethod   String
  
  pixQrCode       String?   @db.Text
  pixQrCodeBase64 String?   @db.Text
  pixTxId         String?   @unique
  
  gateway         String?
  gatewayOrderId  String?   @unique
  gatewayPaymentId String?  @unique
  
  metadata        Json?
  
  subscription    Subscription?
  
  paidAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId, status])
  @@index([gatewayOrderId])
  @@map("transactions")
}

// ==================== NOVO: GESTÃO DE CLÍNICAS ====================

model Clinic {
  id               String   @id @default(uuid())
  name             String
  cnpj             String   @unique
  
  adminId          String
  admin            User     @relation("ClinicAdmin", fields: [adminId], references: [id])
  
  planType         String
  maxProfessionals Int      @default(3)
  
  address          String?
  phone            String?
  email            String?
  
  members          ClinicMember[]
  patients         Patient[]
  sessions         Session[]
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  @@map("clinics")
}

model ClinicMember {
  id             String   @id @default(uuid())
  clinicId       String
  clinic         Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  
  professionalId String
  professional   User     @relation("ClinicMembership", fields: [professionalId], references: [id], onDelete: Cascade)
  
  role           String   @default("professional")
  canViewAll     Boolean  @default(false)
  
  joinedAt       DateTime @default(now())
  
  @@unique([clinicId, professionalId])
  @@map("clinic_members")
}

// ==================== NOVO: PROMPTS IA ====================

model Prompt {
  id             String   @id @default(uuid())
  professionalId String?
  
  text           String   @db.Text
  category       String
  customizable   Boolean  @default(false)
  
  isDefault      Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@map("prompts")
}

// Atualização v3.4.1: Adicionar owner aos prompts
model AIComparativePrompt {
  id                String   @id @default(uuid())
  userId            String?  // NULL = prompt populacional (sistema), UUID = prompt do profissional
  promptType        String   // "population_baseline", "demographic_specific", "custom"
  demographicFilter String?
  promptTemplate    String   @db.Text
  description       String
  isActive          Boolean  @default(true)
  isPublic          Boolean  @default(false) // Se profissional quer compartilhar
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  user              User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([promptType, isActive])
  @@index([userId])
}
