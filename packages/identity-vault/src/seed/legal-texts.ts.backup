import { PrismaClient } from '@prisma/client';
const prisma = new PrismaClient();

const PH = '[AGUARDANDO REDAÇÃO JURÍDICA]';

export async function seedLegalTexts() {
  console.log('📝 Seeding 12 legal texts...');
  
  const texts = [
    { type: 'prof_term', version: '1.0.0', title: 'Termo de Uso Profissional', audience: 'professional', context: 'signup', shortText: 'O FROID é ferramenta de apoio.', content: PH, isBlocking: true, requiresAction: true, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '6', paragraph: 'X', tag: 'resp' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'patient_consent', version: '2.0.0', title: 'Consentimento', audience: 'patient', context: 'session_start', shortText: 'Autorizo gravação.', content: 'TERMO FROID v2.0', isBlocking: true, requiresAction: true, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '7', paragraph: 'I', tag: 'consent' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'privacy_policy', version: '1.0.0', title: 'Política de Privacidade', audience: 'both', context: 'signup', shortText: 'Como protegemos dados.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '9', paragraph: null, tag: 'transp' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'terms_of_use', version: '1.0.0', title: 'Termos de Uso', audience: 'both', context: 'signup', shortText: 'Regras da plataforma.', content: PH, isBlocking: true, requiresAction: true, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'CC', article: '421', paragraph: null, tag: 'contrato' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'patient_rights', version: '1.0.0', title: 'Direitos LGPD Art.18', audience: 'patient', context: 'data_export', shortText: 'Seus direitos.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: true, legalBasis: [{ chapter: 'LGPD', article: '18', paragraph: 'I-IX', tag: 'direitos' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'data_sharing', version: '1.0.0', title: 'Compartilhamento', audience: 'patient', context: 'session_start', shortText: 'Dados só com consentimento.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '7', paragraph: 'I', tag: 'share' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'data_retention', version: '1.0.0', title: 'Retenção de Dados', audience: 'both', context: 'data_export', shortText: 'Quanto tempo guardamos.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '15', paragraph: null, tag: 'retention' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'security_policy', version: '1.0.0', title: 'Segurança', audience: 'both', context: 'signup', shortText: 'Criptografia e controle.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '46', paragraph: null, tag: 'security' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'cookies_policy', version: '1.0.0', title: 'Cookies', audience: 'both', context: 'signup', shortText: 'Cookies essenciais.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'MCI', article: '7', paragraph: 'VII', tag: 'privacy' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'research_use', version: '1.0.0', title: 'Pesquisa', audience: 'patient', context: 'session_start', shortText: 'Dados agregados k≥50.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '7', paragraph: 'IV', tag: 'research' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'incident_notice', version: '1.0.0', title: 'Incidentes', audience: 'both', context: 'data_export', shortText: 'Notificação em 72h.', content: PH, isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'LGPD', article: '48', paragraph: null, tag: 'incident' }], effectiveFrom: new Date('2026-05-04') },
    { type: 'emergency_notice', version: '1.0.0', title: 'Emergência', audience: 'patient', context: 'session_start', shortText: 'SAMU 192, CVV 188.', content: 'Emergência: 192/188', isBlocking: false, requiresAction: false, requiresSignature: false, showCitationInline: false, legalBasis: [{ chapter: 'CFP', article: '1', paragraph: null, tag: 'vida' }], effectiveFrom: new Date('2026-05-04') },
  ];

  for (const text of texts) {
    await prisma.legal_texts.upsert({
      where: { type_version: { type: text.type, version: text.version } },
      update: {},
      create: text,
    });
  }

  console.log('✅ 12 legal texts seeded');
}
